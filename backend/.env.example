APP_NAME=InfluncerCrm
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000
APP_TIMEZONE=Asia/Riyadh
APP_LOCALE=ar
APP_FALLBACK_LOCALE=en

LOG_CHANNEL=daily
LOG_LEVEL=debug

# â”€â”€ Database (MySQL 8.0+) â”€â”€
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=influencercrm
DB_USERNAME=root
DB_PASSWORD=

# â”€â”€ Session & Cache â”€â”€
BROADCAST_DRIVER=log
CACHE_DRIVER=file
CACHE_STORE=file
QUEUE_CONNECTION=sync
SESSION_DRIVER=database
SESSION_LIFETIME=120

# â”€â”€ Sanctum (Stateful Cookie Auth) â”€â”€
SANCTUM_STATEFUL_DOMAINS=localhost:5173,127.0.0.1:5173
SESSION_DOMAIN=

# â”€â”€ Frontend â”€â”€
FRONTEND_URL=http://localhost:5173
FRONTEND_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# â”€â”€ Google OAuth (Phase 2) â”€â”€
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URL=${APP_URL}/api/v1/auth/google/callback

# â”€â”€ Mail â”€â”€
MAIL_MAILER=smtp
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=noreply@influencercrm.sa
MAIL_FROM_NAME="${APP_NAME}"

# â”€â”€ WhatsApp Business Cloud API â”€â”€
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_BUSINESS_ACCOUNT_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_VERIFY_TOKEN=smartcode_webhook_verify_2026
WHATSAPP_API_URL=https://graph.facebook.com/v18.0

# â”€â”€ OpenAI (for AI content analysis) â”€â”€
OPENAI_API_KEY=
OPENAI_ORGANIZATION=
OPENAI_MODEL=gpt-4o-mini

# â”€â”€ SaaS / Security â”€â”€
ADMIN_EMAIL=admin@smartcode.sa
ADMIN_PASSWORD=
SEED_USER_PASSWORD=

# â”€â”€ Laravel Reverb (Phase 8) â”€â”€
REVERB_APP_ID=
REVERB_APP_KEY=
REVERB_APP_SECRET=
REVERB_HOST=localhost
REVERB_PORT=8080
REVERB_SCHEME=http
NOTIFICATION_EMAIL_RECIPIENTS=
